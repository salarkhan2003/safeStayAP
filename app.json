{
  "expo": {
    "name": "SafeStay AP",
    "slug": "safestayap",
    "version": "1.0.0",
    "jsEngine": "hermes",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpeg",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#1a237e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safestayap.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpeg",
        "backgroundColor": "#1a237e"
      },
      "package": "com.safestayap.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/logo.jpeg",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SafeStay AP to access your camera for QR check-in."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SafeStay AP to access your photos for document upload."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.jpeg",
          "color": "#1a237e"
        }
      ]
    ],
    "scheme": "safestayap",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "f78c2d83-6e1a-480e-ae07-ead29af7aad8"
      }
    }
  }
}
